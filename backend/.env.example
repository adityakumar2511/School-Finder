# =============================================================================
# SchoolFinder Backend — Environment Variables (copy to .env)
# Never commit real secrets. Set these in Render/Railway dashboard.
# =============================================================================

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
# Render/Railway inject PORT automatically in production
PORT=4000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Always use sslmode=require for Neon in production
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ─── JWT (backend API auth — keep secret, never expose to frontend) ───────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS (frontend origin — HTTPS in production, no trailing slash) ──────────
# Multiple origins: comma-separated (e.g. https://app.vercel.app,https://www.example.com)
FRONTEND_URL=http://localhost:3000

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── First-time admin setup (one-time seeder: npm run seed:admin) ─────────────
# Used only to create the initial platform admin account. Remove or rotate after use.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# ─── SMTP (password reset emails) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SchoolFinder <your-email@gmail.com>

# ─── Optional ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# Set to true when running behind Render/Railway/nginx (auto-enabled when NODE_ENV=production)
TRUST_PROXY=true
